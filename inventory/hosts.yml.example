---
all:
  children:
    vpn_servers:
      # ── SSH defaults for the whole group ─────────────────────────────────────
      vars:
        ansible_user: root
        ansible_ssh_private_key_file: ~/.ssh/id_rsa
        # ansible_ssh_pass: "your_password"   # alternative to key auth
        ansible_python_interpreter: /usr/bin/python3

        # ── Outline defaults (overridden at host level) ───────────────────────
        outline_server_name: "Outline VPN"
        outline_metrics_enabled: false
        outline_default_port: ~          # ~ = leave unchanged
        outline_default_limit_bytes: ~   # ~ = leave unchanged; 0 = remove limit
        outline_hostname: ~              # ~ = use server IP

      hosts:

        # ── Minimal host — everything taken from group vars ───────────────────
        my-server-1:
          ansible_host: 1.2.3.4
          outline_server_name: "My Server 1"

        # ── Host with password auth and non-standard SSH port ─────────────────
        my-server-2:
          ansible_host: 5.6.7.8
          ansible_port: 2222
          ansible_user: ubuntu
          ansible_ssh_pass: "s3cr3t"
          outline_server_name: "My Server 2"
          outline_default_port: 8388
          outline_default_limit_bytes: 53687091200   # 50 GB
          outline_metrics_enabled: true

        # ── Host with custom hostname in access key URLs ──────────────────────
        my-server-3:
          ansible_host: 9.10.11.12
          outline_server_name: "My Server 3"
          outline_hostname: "vpn.mycompany.com"
          outline_default_port: 443

        # ── Already installed: management_url set manually ────────────────────
        # ── (usually auto-populated after the first deploy) ──────────────────
        # my-server-4:
        #   ansible_host: 11.22.33.44
        #   outline_management_url: "https://11.22.33.44:12345/AbCdEfGhIj"
        #   outline_server_name: "My Server 4"
